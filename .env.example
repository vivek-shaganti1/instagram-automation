# ============================================================
# Instagram AI News Automation — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Google AI Studio (Gemini + Imagen 3) ---
GOOGLE_AI_API_KEY=AIzaSyCRpMkPYr-Hsk5TFOCF7XYTgM7St5LfXPA

# --- Instagram Credentials ---
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# --- Optional: Account Handle shown on slides (default: @yourusername) ---
INSTAGRAM_HANDLE=@your_handle

# --- Posting Config ---
# Number of posts per day
POSTS_PER_DAY=5
# Number of slides per carousel (minimum 4)
SLIDES_PER_POST=5
# Delay between posts in seconds (to avoid rate limiting)
POST_DELAY_SECONDS=45

# --- News Config ---
# How many hours back to search for news (default 24)
NEWS_LOOKBACK_HOURS=24
