datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reel {
  id           String    @id @default(uuid())
  category     String // "ai", "business", "motivation"
  status       String // "PENDING", "GENERATING", "RENDERED", "UPLOADED", "FAILED"
  headline     String
  script       Json
  videoUrl     String? // Cloudinary or storage path
  caption      String
  views        Int       @default(0)
  likes        Int       @default(0)
  comments     Int       @default(0)
  error        String?
  scheduledFor DateTime
  postedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model DailyMetric {
  id          String   @id @default(uuid())
  date        String   @unique // "YYYY-MM-DD"
  totalViews  Int      @default(0)
  targetViews Int      @default(100)
  postCount   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
