    "prisma:migrate": "prisma migrate dev",
    "db:seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@prisma/client": "^5.10.2",
    "axios": "^1.6.7",
    "bullmq": "^5.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.24",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.10.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
