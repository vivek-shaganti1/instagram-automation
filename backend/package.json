{
  "name": "instagram-automation-backend",
  "version": "1.0.0",
  "description": "Backend worker and API server for Instagram Reels automation SaaS",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
